{
  "compilerOptions": {
    "composite": true,
    "outDir": "./out-ts/web",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@data/*": ["./src/data/*"]
    }
  },
  "include": ["src/renderer/src/**/*", "src/data/**/*"]
}
