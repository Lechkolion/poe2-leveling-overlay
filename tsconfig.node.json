{
  "compilerOptions": {
    "composite": true,
    "outDir": "./out-ts/node",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node", "node"],
    "paths": {
      "@data/*": ["./src/data/*"]
    }
  },
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*"]
}
